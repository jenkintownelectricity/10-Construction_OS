{
  "contract_id": "construction_kernel.graph_reference.v1",
  "version": "1.0",
  "authority": "Construction_Kernel",
  "contract_type": "governed_graph_reference_contract",
  "description": "Defines the graph reference contract governing the node and edge structure of the construction knowledge graph. All graph references must conform to governed node types, edge types, and structural constraints. Runtime must validate graph references against this contract and must not define its own node or edge types.",
  "governance_source": "GOVERNANCE_KERNEL.md",
  "architecture_source": "ASSEMBLY_KERNEL.md",
  "fail_closed_rule": "Any graph reference containing an unrecognized node_type or edge_type must be rejected. Runtime must not invent graph topology.",
  "valid_node_types": [
    "project",
    "building",
    "level",
    "zone",
    "assembly",
    "sub_assembly",
    "component",
    "material",
    "interface",
    "detail",
    "drawing",
    "sheet",
    "specification_section",
    "schedule_item",
    "inspection_point",
    "submittal",
    "rfi",
    "issue",
    "blocker",
    "remediation"
  ],
  "valid_edge_types": [
    "contains",
    "composed_of",
    "interfaces_with",
    "attaches_to",
    "seals_against",
    "overlaps",
    "depends_on",
    "blocks",
    "resolves",
    "references",
    "supersedes",
    "derived_from",
    "applies_to",
    "specifies",
    "inspects",
    "terminates_at",
    "bears_on",
    "drains_to"
  ],
  "graph_constraints": {
    "allow_cycles": false,
    "max_depth": 12,
    "root_node_types": ["project"],
    "orphan_policy": "reject",
    "duplicate_edge_policy": "reject"
  }
}