{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "construction_kernel.schemas.evidence_schema",
  "title": "Evidence Schema Contract Schema",
  "description": "Schema definition for governed evidence objects. Owned by Construction_Kernel. Evidence records track the provenance of extracted data from source documents, linking extraction methods, confidence scores, and extracted entities to their source material. Runtime must validate evidence against this schema and must not define its own.",
  "authority": "Construction_Kernel",
  "type": "object",
  "required": ["contract_id", "version", "authority", "contract_type", "evidence_fields"],
  "properties": {
    "contract_id": {
      "type": "string",
      "pattern": "^construction_kernel\\.evidence_schema\\."
    },
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "authority": {
      "type": "string",
      "const": "Construction_Kernel"
    },
    "contract_type": {
      "type": "string",
      "const": "governed_evidence_schema"
    },
    "description": { "type": "string" },
    "governance_source": { "type": "string" },
    "architecture_source": { "type": "string" },
    "fail_closed_rule": { "type": "string" },
    "evidence_fields": {
      "type": "object",
      "required": ["required", "optional"],
      "properties": {
        "required": {
          "type": "array",
          "items": { "type": "string" }
        },
        "optional": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "valid_extraction_methods": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "Governed list of valid extraction methods that may appear in evidence records."
    },
    "valid_source_document_types": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "Governed list of valid source document types."
    },
    "confidence_range": {
      "type": "object",
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "number", "minimum": 0.0 },
        "max": { "type": "number", "maximum": 1.0 }
      }
    },
    "evidence_item_schema": {
      "type": "object",
      "description": "Schema for individual evidence items within a collection.",
      "required": ["evidence_id", "source_document", "extraction_method", "confidence", "extracted_entities", "timestamps"],
      "properties": {
        "evidence_id": {
          "type": "string",
          "pattern": "^ev-[a-z0-9\\-]+$",
          "description": "Unique identifier for the evidence record."
        },
        "source_document": {
          "type": "object",
          "required": ["document_id", "document_type", "document_name"],
          "properties": {
            "document_id": { "type": "string" },
            "document_type": { "type": "string" },
            "document_name": { "type": "string" },
            "page_ref": { "type": "string" },
            "section_ref": { "type": "string" }
          }
        },
        "extraction_method": {
          "type": "string",
          "description": "Must be one of valid_extraction_methods."
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Confidence score for the extraction, between 0.0 and 1.0."
        },
        "extracted_entities": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["entity_type", "entity_value"],
            "properties": {
              "entity_type": { "type": "string" },
              "entity_value": { "type": "string" },
              "entity_ref": { "type": "string" },
              "span_start": { "type": "integer" },
              "span_end": { "type": "integer" }
            }
          }
        },
        "timestamps": {
          "type": "object",
          "required": ["extracted_at"],
          "properties": {
            "extracted_at": { "type": "string", "format": "date-time" },
            "validated_at": { "type": "string", "format": "date-time" },
            "expired_at": { "type": "string", "format": "date-time" }
          }
        }
      }
    }
  },
  "additionalProperties": true
}