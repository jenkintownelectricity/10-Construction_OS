{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "construction_kernel.schemas.graph_reference_contract",
  "title": "Graph Reference Contract Schema",
  "description": "Schema definition for governed graph reference objects. Owned by Construction_Kernel. Graph references define the node and edge structure for the construction knowledge graph, including parent-child relationships, edge types, and node classification. Runtime must validate graph references against this schema and must not define its own.",
  "authority": "Construction_Kernel",
  "type": "object",
  "required": ["contract_id", "version", "authority", "contract_type", "valid_node_types", "valid_edge_types"],
  "properties": {
    "contract_id": {
      "type": "string",
      "pattern": "^construction_kernel\\.graph_reference\\."
    },
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "authority": {
      "type": "string",
      "const": "Construction_Kernel"
    },
    "contract_type": {
      "type": "string",
      "const": "governed_graph_reference_contract"
    },
    "description": { "type": "string" },
    "governance_source": { "type": "string" },
    "architecture_source": { "type": "string" },
    "fail_closed_rule": { "type": "string" },
    "valid_node_types": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "Governed list of valid node types in the construction graph."
    },
    "valid_edge_types": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "Governed list of valid edge types in the construction graph."
    },
    "graph_ref_item_schema": {
      "type": "object",
      "description": "Schema for individual graph reference entries.",
      "required": ["graph_ref", "node_type"],
      "properties": {
        "graph_ref": {
          "type": "string",
          "pattern": "^gr-[a-z0-9\\-]+$",
          "description": "Unique graph reference identifier."
        },
        "node_type": {
          "type": "string",
          "description": "Must be one of valid_node_types."
        },
        "parent_ref": {
          "type": ["string", "null"],
          "description": "Graph reference of the parent node. Null for root nodes."
        },
        "child_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Graph references of child nodes."
        },
        "edge_type": {
          "type": "string",
          "description": "Must be one of valid_edge_types. Describes the relationship from parent to this node."
        },
        "node_label": { "type": "string" },
        "node_metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "graph_constraints": {
      "type": "object",
      "properties": {
        "allow_cycles": { "type": "boolean", "default": false },
        "max_depth": { "type": "integer", "minimum": 1 },
        "root_node_types": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": true
}